# Detect if on battery
[ "$(cat /sys/class/power_supply/BAT0/status)" = "Discharging" ] && echo yes || echo no

set $screen_off sh -c '[ "$(cat /sys/class/power_supply/BAT0/status)" = "Discharging" ] && swaymsg "output * dpms off" || true'
set $screen_on swaymsg "output * dpms on"

exec_always swayidle -w \
  timeout 300 $screen_off \
  resume $screen_on


